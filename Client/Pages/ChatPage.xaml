<Page
    x:Class="Client.Pages.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:data="using:Client.Models"
    Width="auto"
    xmlns:local="using:Client.Pages">

    <Page.Resources>
        <DataTemplate x:Key="OtherMessageTemplate" x:DataType="data:ChatMessageModel">
            <StackPanel HorizontalAlignment="Left">
                <Border CornerRadius="10" Padding="10" Margin="5" MaxWidth="400">
                    <Border.Background>
                        <SolidColorBrush Color="LightGray"/>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" Spacing="10" MinWidth="180">
                        <Image Source="{x:Bind Avatar}" Width="40" Height="40"/>
                        <StackPanel MinWidth="200">
                            <TextBlock Text="{x:Bind Header}" FontWeight="Bold"/>
                            <TextBlock Text="{x:Bind Content}" TextWrapping="Wrap"/>
                            <TextBlock Text="{x:Bind TimeFormatted}" FontSize="12" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="MyMessageTemplate" x:DataType="data:ChatMessageModel">
            <Border CornerRadius="10" Padding="10" Margin="5" MaxWidth="800" HorizontalAlignment="Right" Background="LightBlue">
                <StackPanel Orientation="Horizontal" Spacing="10" MinWidth="180">
                    <Image Source="{x:Bind Avatar}" Width="40" Height="40" VerticalAlignment="Top"/>
                    <StackPanel MinWidth="200">
                        <TextBlock Text="{x:Bind Header}" FontWeight="Bold"/>
                        <TextBlock Text="{x:Bind Content}" TextWrapping="Wrap" MaxWidth="500" HorizontalAlignment="Left"/>
                        <TextBlock Text="{x:Bind TimeFormatted}" FontSize="12" HorizontalAlignment="Right"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="LoadMoreTemplate" x:DataType="data:LoadMorePlaceholder">
            <Button Content="Load more" Click="LoadMore_Click" HorizontalAlignment="Center" Margin="10"/>
        </DataTemplate>

        <DataTemplate x:Key="EmptyTemplate" x:DataType="data:EmptyPlaceholder">
            <TextBlock Text="{x:Bind Message}" HorizontalAlignment="Center" FontStyle="Italic" Foreground="Gray" Margin="10"/>
        </DataTemplate>

        <DataTemplate x:Key="IrcMessageTemplate" x:DataType="data:ChatMessageModel">
            <TextBlock FontFamily="Consolas" TextWrapping="Wrap" MaxWidth="1000" Text="{x:Bind IrcHeader}"/>
        </DataTemplate>

        <data:ChatMessageTemplateSelector x:Key="MessageTemplateSelector"
            MyUsername="Moi"
            MyMessageTemplate="{StaticResource MyMessageTemplate}"
            OtherMessageTemplate="{StaticResource OtherMessageTemplate}"
            IrcTemplate="{StaticResource IrcMessageTemplate}"
            LoadMoreTemplate="{StaticResource LoadMoreTemplate}"
            EmptyTemplate="{StaticResource EmptyTemplate}" />

        <Style x:Key="CompactItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="BubbleItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <DataTemplate x:Key="UserTemplate" x:DataType="data:UserInfo">
            <StackPanel Orientation="Horizontal" Spacing="8" Padding="4">
                <Image Source="{x:Bind Avatar}" Width="32" Height="32"/>
                <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="10" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Pivot x:Name="RoomsPivot" Grid.Column="0" Grid.RowSpan="2" />

        <ListView x:Name="UsersList" Grid.Column="2" SelectionMode="Single" ItemTemplate="{StaticResource UserTemplate}" />

        <ListView x:Name="MessagesList" Grid.Column="1" ItemTemplateSelector="{StaticResource MessageTemplateSelector}" SelectionMode="None"/>

        <TextBox x:Name="InputBox" Grid.Column="1" Grid.Row="1" PlaceholderText="Votre message..." KeyDown="InputBox_KeyDown"/>
    </Grid>
</Page>
